// there is no need to disclose the parameters of unexported circuits.
circuit graham(a: Field, b: Field): Field {
  return a - b;
}

export circuit paulo() : Field{
  return graham(disclose(brad()), disclose(brad()));
}

constructor(f: Uint<8>, z: Uint<8>, u: Vector<1, Uint<8>>) {
  if (disclose(f) > 0) {
    set.insert(default<QualifiedShieldedCoinInfo>);
  } else {
    const p = default<Boolean>;
    if(p && disclose(f) > 0) {
      set.insertCoin(default<ShieldedCoinInfo>, default<Either<ZswapCoinPublicKey, ContractAddress>>);
    } else {
      if(disclose(u[0]) > 0) {
        set.member(default<QualifiedShieldedCoinInfo>);
      } else {
        if(disclose(f + z) > 0) {
          set.remove(default<QualifiedShieldedCoinInfo>);
        } else {
          if(disclose(z - f) < 0) {
            const z = 8;
            const f = 4;

            if(z + f > 0) {
              set.size();
            } else {
              const p = z;
              if (p > 0) {
                set.resetToDefault();
              }
            }
          }
        }
      }
    }
  }
}
