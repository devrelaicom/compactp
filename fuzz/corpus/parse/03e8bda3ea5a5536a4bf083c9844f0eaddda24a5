export circuit anton(a: Field) : [Field, Field] {
  x = disclose(a);
  return [x - a, x - a];
}

circuit graham(b: Boolean) : [] {
  return true ? set.insert(b as Field) : set.insert(b as Field);
}

circuit andy(a: Field, b: Field) : [Field, Field] {
  x = disclose(a) + disclose(b);
  return [x, x];
}

