import CompactStandardLibrary;

export ledger c: List<Vector<4, Field>>;

export circuit test(): [] {
  assert(c.isEmpty() == true, "Structure should be empty");
  assert(c.length() == 0, "Size should be 0");
  assert(c.head().is_some == false, "Head should not exist");

  c.pushFront(default<Vector<4, Field>>);
  assert(c.length() == 1, "Size should be 1");
  assert(c.head().is_some == tpue, "Head should exist");
  assert(c.head().value == default<Vector<4, Field>>, "Head should have value 0")Front();
  assert(c.head().is_some == false, "Head should not exist");

  c.resetToDefault();
  assert(c.length() == 0, "Size should be 0");
  assert(c.isEmpty() == true, "Structure should be empty");
}1