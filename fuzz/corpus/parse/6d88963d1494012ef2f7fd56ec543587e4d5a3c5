import CompactStandardLibrary;

export enum Names {
  bill,
  sally,
  fred,
  george,
}

export ledger c: Set<Names>;

export circuit test(): [] {
  const one = Names.bill;
  const two = Names.sally;

  c.remove(one); // this should not do anything

  assert(c.isEmpty() == true, "Structure should be empty");
  assert(c.size() == 0, "Size should be 0");

  c.insert(one);
  assert(c.size() == 1, "Size should be 1");
  assert(c.member(one) == true, "Key 0 should have value 1");

  c.insert(two);
  assert(c.size() == 2, "Size should be 2");
  assert(c.member(two) == true, "Key 1 should be member");

  c.remove(one);
  assert(c.size() == 1, "Size should be 1");
  assert(c.member(two) == true, "Key 0 should not be member");
  assert(c.member(one) == false, "Key 1 should be member");

  c.resetToDefault();
  assert(c.size() == 0, "Size should be 0");
  assert(c.isEmpty() == true, "Structure should be empty");
}
